---
import Layout from '../layouts/Layout.astro';
import { branches } from '../data/branches.js';
import { menu } from '../data/menu.js';

import mainImg from "../img/main.jpg";
import food1Img from "../img/food1.jpg";
import food2Img from "../img/food2.webp";
import IndoorImg from "../img/indoor.jpeg";
import food3Img from "../img/food3.webp";

// Tüm menü kalemlerini filtreleme için düz bir listeye çeviriyoruz
const allItems = menu.flatMap(cat => 
  cat.items.map(item => ({ ...item, categoryName: cat.category }))
);

// Menüdeki tüm benzersiz etiketleri (tags) çekiyoruz
const allTags = [...new Set(allItems.flatMap(item => item.tags || []))];

// MERKEZİ GÖRSEL YÖNETİMİ
const imgPool = {
  hero: mainImg.src,
  durum: food1Img.src,
  iskender: food2Img.src,
  ates: IndoorImg.src,
  lavas: food3Img.src
};
---

<Layout title="Efesos Döner | Gaziantep'in Lezzet İmzası">
    <!-- NAVBAR -->
    <nav class="fixed top-0 w-full z-50 bg-white/95 backdrop-blur-md border-b border-gray-100 py-4 px-6 flex justify-between items-center">
        <span class="text-2xl font-black text-efesos-red italic tracking-tighter">EFESOS</span>
        <div class="hidden md:flex gap-8 font-bold text-xs uppercase tracking-widest text-efesos-dark">
            <a href="#menu" class="hover:text-efesos-red transition-colors">MENÜ</a>
            <a href="#galeri" class="hover:text-efesos-red transition-colors">GALERİ</a>
            <a href="#subeler" class="hover:text-efesos-red transition-colors">ŞUBELERİMİZ</a>
        </div>
        <a href="#subeler" class="bg-efesos-red text-white px-6 py-2 rounded-full text-xs font-black uppercase tracking-tighter shadow-lg shadow-efesos-red/20 hover:scale-105 transition-transform">SİPARİŞ VER</a>
    </nav>

    <!-- HERO SECTION -->
    <header class="relative h-screen flex items-center justify-center text-center px-4 pt-16 bg-efesos-red overflow-hidden">
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-efesos-red via-red-900 to-black opacity-90"></div>
            <img src={imgPool.hero} class="w-full h-full object-cover opacity-40 grayscale-[0.2]" alt="Efesos Döner" />
            <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-efesos-dark"></div>
        </div>
        
        <div class="z-10 mt-10">
            <h1 class="text-7xl md:text-[11rem] font-black text-efesos-yellow italic leading-none drop-shadow-2xl mb-2">EFESOS</h1>
            <p class="text-white text-xl md:text-3xl font-bold tracking-[0.4em] uppercase mb-12 drop-shadow-lg italic">GAZİANTEP'İN LEZZET İMZASI</p>
            <div class="flex flex-col md:flex-row gap-4 justify-center items-center">
                <a href="#menu" class="px-12 py-5 bg-efesos-yellow text-efesos-red font-black rounded-2xl text-xl hover:bg-white transition-all shadow-2xl">MENÜYÜ KEŞFET</a>
                <a href="#subeler" class="px-12 py-5 border-2 border-white/30 backdrop-blur-md text-white font-black rounded-2xl text-xl hover:bg-white hover:text-efesos-red transition-all">SİPARİŞ HATLARI</a>
            </div>
        </div>
    </header>

    <!-- MENU SECTION -->
    <section id="menu" class="py-24 bg-white">
        <div class="max-w-6xl mx-auto px-4">
            <div class="text-center mb-12">
                <h2 class="text-5xl font-black italic text-efesos-dark uppercase tracking-tighter">LEZZET LİSTESİ</h2>
                <div class="h-1.5 w-24 bg-efesos-yellow mx-auto mt-4 mb-8"></div>
                
                <!-- FİLTRE BUTONLARI -->
                <div class="flex flex-wrap justify-center gap-3">
                    <button class="filter-btn active" data-filter="all">TÜMÜ</button>
                    {allTags.map(tag => (
                        <button class="filter-btn" data-filter={tag}>{tag.toUpperCase()}</button>
                    ))}
                </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8" id="menu-container">
                {allItems.map(item => (
                    <div class="menu-item bg-gray-50 p-8 rounded-[2.5rem] border border-gray-100 shadow-sm transition-all duration-300" 
                         data-tags={JSON.stringify(item.tags || [])}>
                        <div class="flex justify-between items-start">
                            <div class="pr-6">
                                <!-- ROZETLER (BADGES) -->
                                <div class="flex flex-wrap gap-2 mb-3">
                                    {item.tags?.map(tag => {
                                        let badgeStyle = "bg-gray-200 text-gray-700";
                                        if (tag.includes('Popüler')) badgeStyle = "bg-efesos-red text-white";
                                        else if (tag.includes('Uygun Fiyat')) badgeStyle = "bg-efesos-yellow text-efesos-red";
                                        else if (tag.includes('Vejetaryen')) badgeStyle = "bg-green-600 text-white";
                                        else if (tag.includes('Döner')) badgeStyle = "bg-orange-100 text-orange-800 border border-orange-200";
                                        else if (tag.includes('İçecekler')) badgeStyle = "bg-blue-100 text-blue-800 border border-blue-200";
                                        else if (tag.includes('Yan Ürünler') || tag.includes('Soslar')) badgeStyle = "bg-purple-100 text-purple-800 border border-purple-200";

                                        return (
                                            <span class={`text-[10px] font-black px-2 py-1 rounded-md uppercase tracking-tighter shadow-sm ${badgeStyle}`}>
                                                {tag}
                                            </span>
                                        )
                                    })}
                                </div>
                                <h4 class="font-bold text-2xl text-efesos-dark italic">{item.name}</h4>
                                <p class="text-gray-400 text-sm italic mt-1">{item.desc}</p>
                            </div>
                            <span class="font-black text-efesos-red bg-white px-4 py-2 rounded-xl border border-gray-100 shadow-sm whitespace-nowrap">{item.price}</span>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- GALERİ SECTION -->
    <section id="galeri" class="py-24 bg-[#fafafa]">
        <div class="max-w-7xl mx-auto px-4">
            <div class="mb-16">
                <h2 class="text-6xl font-black italic text-efesos-dark tracking-tighter leading-none">LEZZET <br/> <span class="text-efesos-red">VİTRİNİ</span></h2>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
                <div class="gallery-item col-span-2 row-span-2 h-[450px] md:h-[600px] relative overflow-hidden rounded-[2.5rem]">
                    <img src={imgPool.durum} class="w-full h-full object-cover" alt="Dürüm" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                </div>
                <div class="gallery-item h-[215px] md:h-[285px] relative overflow-hidden rounded-[2rem]">
                    <img src={imgPool.ates} class="w-full h-full object-cover" alt="Ateş" />
                </div>
                <div class="gallery-item h-[215px] md:h-[285px] relative overflow-hidden rounded-[2rem]">
                    <img src={imgPool.iskender} class="w-full h-full object-cover" alt="Sunum" />
                </div>
                <div class="gallery-item col-span-2 h-[215px] md:h-[285px] relative overflow-hidden rounded-[2.5rem]">
                    <img src={imgPool.lavas} class="w-full h-full object-cover" alt="Lavaş" />
                </div>
            </div>
        </div>
    </section>

    <!-- SUBELER SECTION -->
    <section id="subeler" class="py-24 bg-efesos-dark relative overflow-hidden">
        <div class="max-w-7xl mx-auto px-4 relative z-10">
            <div class="text-center mb-16">
                <h2 class="text-5xl font-black text-white italic tracking-tighter underline decoration-efesos-yellow underline-offset-8 uppercase">ŞUBELERİMİZ</h2>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {branches.map(b => (
                    <div class="bg-white/5 backdrop-blur-md p-8 rounded-[2.5rem] border border-white/10 hover:border-efesos-yellow transition-all group">
                        <div class="w-14 h-14 bg-efesos-yellow/10 rounded-2xl flex items-center justify-center mb-6 text-3xl">📍</div>
                        <h3 class="text-2xl font-black text-white mb-3 italic uppercase group-hover:text-efesos-yellow transition-colors">{b.name}</h3>
                        <p class="text-gray-400 text-sm mb-8 italic">{b.address}</p>
                        <div class="space-y-3">
                            <a href={`https://wa.me/${b.whatsapp.replace(/\D/g,'')}?text=Merhaba%20Efesos%20Döner,%20sipariş%20vermek%20istiyorum.`} 
                               target="_blank"
                               class="block w-full bg-[#25D366] text-white text-center py-4 rounded-2xl font-black text-xs uppercase transition-all active:scale-95 shadow-lg shadow-green-500/20">
                               WHATSAPP SİPARİŞ
                            </a>
                            <a href={b.coords} target="_blank" class="block w-full bg-white/5 text-white text-center py-4 rounded-2xl font-bold text-[10px] uppercase border border-white/5 hover:bg-white/10 transition-colors">KONUM</a>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="bg-black py-16 text-center border-t border-white/5">
        <p class="text-white/20 text-xs font-black tracking-widest uppercase italic">© 2026 EFESOS DÖNER SALONU | BY C0MBLASTERR</p>
    </footer>

    <!-- FILTRELEME SCRIPT'I -->
    <script>
        const buttons = document.querySelectorAll('.filter-btn');
        const items = document.querySelectorAll('.menu-item');

        buttons.forEach(btn => {
            btn.addEventListener('click', () => {
                buttons.forEach(b => b.classList.remove('active', 'bg-efesos-red', 'text-white'));
                btn.classList.add('active', 'bg-efesos-red', 'text-white');

                const filter = btn.getAttribute('data-filter');

                items.forEach(item => {
                    const tags = JSON.parse(item.getAttribute('data-tags'));
                    const htmlItem = item as HTMLElement;
                    if (filter === 'all' || tags.includes(filter)) {
                        htmlItem.style.display = 'block';
                        setTimeout(() => htmlItem.style.opacity = '1', 10);
                    } else {
                        htmlItem.style.opacity = '0';
                        setTimeout(() => htmlItem.style.display = 'none', 300);
                    }
                });
            });
        });
    </script>

    <style>
        /* Tailwind v4 referansı */
        @reference "../styles/global.css";

        .filter-btn {
            @apply px-6 py-2 rounded-full border-2 border-gray-100 font-black text-xs transition-all hover:border-efesos-red;
        }
        .filter-btn.active {
            @apply bg-efesos-red border-efesos-red text-white shadow-lg shadow-efesos-red/20;
        }
    </style>
</Layout>
